---

---

<section
  id="hero"
  class="relative min-h-screen flex items-center px-6 md:px-12 lg:px-24 py-24 overflow-hidden"
>
  <!-- fondo, solo visible debajo de lg -->

  <div class="absolute inset-0 lg:hidden" aria-hidden="true">
    <img
      src="https://res.cloudinary.com/dflhguvio/image/upload/v1770923965/_DSC0252_h2mnb4.jpg"
      alt=""
      class="w-full h-full object-cover object-[center_20%]"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-black/55"></div>
  </div>

  <div class="container mx-auto max-w-7xl relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="space-y-8">
        <div class="space-y-4">
          <h1
            class="text-7xl md:text-8xl lg:text-9xl font-bold tracking-tight text-off-white leading-none"
          >
            Le<br />Prof
          </h1>
          <div
            class="flex flex-col text-sm text-off-white/60 tracking-wider uppercase space-y-1"
          >
            <span id="hero-role">Music Producer / DJ</span>
            <span id="hero-location">Chihuahua – Mexico</span>
          </div>
        </div>
      </div>
      <div class="hidden lg:block">
        <div class="relative aspect-[3/4] overflow-hidden">
          <img
            src="https://res.cloudinary.com/dflhguvio/image/upload/v1770923965/_DSC0252_h2mnb4.jpg"
            alt="Artist"
            class="w-full h-full object-cover"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { getInitialLanguage, getTranslations } from "../lib/i18n";
  import type { Language } from "../lib/i18n";

  let currentLanguage: Language = getInitialLanguage();

  function updateHeroTranslations() {
    const t = getTranslations(currentLanguage);

    const roleEl = document.getElementById("hero-role");
    const locationEl = document.getElementById("hero-location");

    if (roleEl) roleEl.textContent = t.hero.role;
    if (locationEl) locationEl.textContent = t.hero.location;
  }

  window.addEventListener("languagechange", ((e: CustomEvent) => {
    currentLanguage = e.detail.language;
    updateHeroTranslations();
  }) as EventListener);

  updateHeroTranslations();
</script>
