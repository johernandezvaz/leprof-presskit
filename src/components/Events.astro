---
const venues = [
  { venue: "The Caffeine Rave", city: "Prague", country: "Czech Republic",
    appearances: [{ date: "2026-02", flyer: "https://res.cloudinary.com/dflhguvio/image/upload/v1770924237/WhatsApp_Image_2026-02-12_at_1.19.30_PM_hqno5p.jpg" }] },
  { venue: "El Camino Mezcaleria", city: "Chihuahua", country: "Mexico",
    appearances: [
      { date: "2026-04", flyer: "https://res.cloudinary.com/dflhguvio/image/upload/v1783534535/agora_beats_flyer_1_fhtt4n.jpg" },
      { date: "2026-04", flyer: "https://res.cloudinary.com/dflhguvio/image/upload/v1783534535/electro_jugueton_flyer_ibgqnw.jpg" },
      { date: "2026-05", flyer: "https://res.cloudinary.com/dflhguvio/image/upload/v1783534536/agora_beats_flyer_2_emrwc6.jpg" },
      { date: "2026-07", flyer: "https://res.cloudinary.com/dflhguvio/image/upload/v1783534535/electro_room_flyer_bxsbrz.jpg" },
      { date: "2026-07", flyer: "https://res.cloudinary.com/dflhguvio/image/upload/v1770924645/WhatsApp_Image_2026-02-12_at_1.29.51_PM_bdx4tk.jpg" }
    ] },
  { venue: "Epicentro Foro", city: "Chihuahua", country: "Mexico",
    appearances: [{ date: "2026-07", flyer: "https://res.cloudinary.com/dflhguvio/image/upload/v1783534534/epicentro_foro_flyer_vorook.jpg" }] },
  { venue: "La Cerve", city: "Chihuahua", country: "Mexico",
    appearances: [{ date: "2026-06", flyer: "https://res.cloudinary.com/dflhguvio/image/upload/v1783534536/la_cerve_flyer_wgo8jo.jpg" }] },
  { venue: "Studio Bar", city: "Chihuahua", country: "Mexico",
    appearances: [
      { date: "2025-05", flyer: "https://res.cloudinary.com/dflhguvio/image/upload/v1770924380/WhatsApp_Image_2026-02-12_at_1.26.02_PM_plveyh.jpg" },
      { date: "2025-09", flyer: "https://res.cloudinary.com/dflhguvio/image/upload/v1770924537/WhatsApp_Image_2026-02-12_at_1.28.38_PM_guu2d8.jpg" }
    ] },
  { venue: "Ambar", city: "Chihuahua", country: "Mexico",
    appearances: [{ date: "2025-06", flyer: "https://res.cloudinary.com/dflhguvio/image/upload/v1770924474/WhatsApp_Image_2026-02-12_at_1.27.33_PM_sznsub.jpg" }] }
];
---

<section id="venues" class="py-32 px-6 md:px-12 lg:px-24">
  <div class="container mx-auto max-w-5xl">
    <h2 id="venues-title" class="text-sm uppercase tracking-ultra-wide text-off-white/40 mb-16">
      Performed At
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      {venues.map((venue) => (
        <div>
          <h3 class="text-2xl md:text-3xl font-light text-off-white mb-1">
            {venue.venue}
          </h3>
          <p class="text-sm text-off-white/50 mb-6">
            {venue.city}, {venue.country}
          </p>
          <div
            class="grid gap-3"
            style={`grid-template-columns: repeat(${Math.min(venue.appearances.length, 3)}, 1fr)`}
          >
            {venue.appearances.map((appearance) => (
              <button
                class="venue-thumb block w-full focus:outline-none"
                data-flyer={appearance.flyer}
                data-caption={appearance.date ? `${venue.venue} — ${appearance.date}` : venue.venue}
              >
                <img
                  src={appearance.flyer}
                  alt={appearance.date ? `${venue.venue} — ${appearance.date}` : venue.venue}
                  class="aspect-[3/4] w-full object-cover"
                  loading="lazy"
                />
              </button>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<div id="venue-lightbox" class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 hidden" role="dialog" aria-modal="true">
  <button id="venue-lightbox-close" class="absolute top-6 right-6 text-off-white/70 hover:text-off-white text-3xl leading-none" aria-label="Close">&times;</button>
  <div id="venue-lightbox-inner" class="relative max-w-2xl w-full mx-6">
    <img id="venue-lightbox-img" src="" alt="" class="w-full h-auto" />
    <p id="venue-lightbox-caption" class="mt-3 text-sm text-off-white/50 text-center"></p>
  </div>
</div>

<script>
  const lightbox  = document.getElementById('venue-lightbox')!;
  const lbImg     = document.getElementById('venue-lightbox-img') as HTMLImageElement;
  const lbCaption = document.getElementById('venue-lightbox-caption')!;
  const lbClose   = document.getElementById('venue-lightbox-close')!;

  document.querySelectorAll<HTMLButtonElement>('.venue-thumb').forEach((btn) => {
    btn.addEventListener('click', () => {
      lbImg.src             = btn.dataset.flyer!;
      lbImg.alt             = btn.dataset.caption!;
      lbCaption.textContent = btn.dataset.caption!;
      lightbox.classList.remove('hidden');
    });
  });

  function closeLightbox() { lightbox.classList.add('hidden'); }

  lbClose.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>

<script>
  import { getInitialLanguage, getTranslations } from '../lib/i18n';
  import type { Language } from '../lib/i18n';

  let currentLanguage: Language = getInitialLanguage();

  function updateVenuesTranslations() {
    const t = getTranslations(currentLanguage);

    const titleEl = document.getElementById('venues-title');
    if (titleEl) titleEl.textContent = t.venues.title;
  }

  window.addEventListener('languagechange', ((e: CustomEvent) => {
    currentLanguage = e.detail.language;
    updateVenuesTranslations();
  }) as EventListener);

  updateVenuesTranslations();
</script>

<style>
  .venue-thumb img {
    transition: opacity 200ms ease;
  }
  .venue-thumb:hover img {
    opacity: 0.75;
  }
  :root {
    --accent: #c6a75e;
  }
</style>
